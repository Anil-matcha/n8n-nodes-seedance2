{
  "name": "n8n-nodes-seedance2",
  "version": "1.0.0",
  "description": "Powerful n8n community node for ByteDance Seedance 2.0. Automate high-quality AI video generation, Text-to-Video, Image-to-Video, and Video Extension with native audio-visual sync in n8n workflows.",
  "keywords": [
    "n8n-community-node-package",
    "seedance",
    "seedance-2.0",
    "bytedance",
    "ai-video-generation",
    "text-to-video",
    "image-to-video",
    "generative-ai",
    "sora-alternative",
    "ai-automation",
    "video-ai",
    "workflow-automation",
    "muapi",
    "byte-dance",
    "ai-video-extension",
    "watermark-remover",
    "no-code-ai",
    "video-editor-ai",
    "low-code-automation",
    "multimodal-ai"
  ],
  "license": "MIT",
  "homepage": "https://muapi.ai",
  "author": {
    "name": "Anil Matcha",
    "email": "support@muapi.ai"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Anil-matcha/n8n-nodes-seedance2"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && npm run build:icons",
    "build:icons": "gulp build:icons",
    "format": "prettier nodes credentials utils --write",
    "lint": "eslint nodes credentials utils --ext .ts",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/Seedance2Api.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Seedance2Predictor/Seedance2Predictor.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-n8n-nodes-base": "^1.0.0",
    "gulp": "^4.0.0",
    "n8n-core": "^1.108.0",
    "n8n-workflow": "^1.106.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "form-data": "^4.0.0"
  }
}
